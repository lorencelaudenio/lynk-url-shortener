RewriteEngine On

# Ignore real files/folders
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# PROFILE ROUTE (@username)
RewriteRule ^@([A-Za-z0-9_-]+)$ bio.php?username=$1 [L,QSA]

# SHORT LINKS (ONLY if not real file)
RewriteCond %{REQUEST_FILENAME}.php !-f
RewriteRule ^([A-Za-z0-9_-]+)$ redirect.php?code=$1 [L,QSA]

# AUTO PHP ROUTING (clean URLs)
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([A-Za-z0-9_-]+)$ $1.php [L,QSA]